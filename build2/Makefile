# target to generate assembly for a file
src/scene/Star.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\SolarSystem.dir\build.make CMakeFiles/SolarSystem.dir/src/scene/Star.cpp.s
.PHONY : src/scene/Star.cpp.s

thirdparty/glad/src/glad.obj: thirdparty/glad/src/glad.c.obj
.PHONY : thirdparty/glad/src/glad.obj

# target to build an object file
thirdparty/glad/src/glad.c.obj:
	$(MAKE) $(MAKESILENT) -f CMakeFiles\glad.dir\build.make CMakeFiles/glad.dir/thirdparty/glad/src/glad.c.obj
